# ==============================================================================
# CAMSENSE AI - INTERVIEW ENGINE CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and populate the values for local assessment testing.
# Never commit the actual '.env' containing active security keys to version control.
# ==============================================================================

# API Server Port
PORT=5000

# Live MongoDB Database Connection String
# Defaults to your local MongoDB server port
MONGO_URI=mongodb://127.0.0.1:27017/ai_interview_platform
DATABASE_URL=mongodb://127.0.0.1:27017/ai_interview_platform

# Cryptographic Token JWT Signature Key
# Replace this with a highly secure random string for production deployments
JWT_SECRET=your_jwt_secret_here

# Ollama Local LLM API Port Integration
# Configured for standard Ollama deployments
OLLAMA_API_URL=http://localhost:11434

# Google Gemini API Key for intelligent, high-fidelity skill extraction and matching
GEMINI_API_KEY=your_gemini_api_key_here
