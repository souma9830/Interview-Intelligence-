# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to "true" to allow demo token in development mode only
ALLOW_DEMO_TOKEN=false

# ─────────────────────────────────────────────
# Storage Configuration
# ─────────────────────────────────────────────
# Supported values: file, memory, mongodb
STORAGE_PROVIDER=file
MONGO_URI=mongodb://localhost:27017/camsense-ai
MONGODB_URI=mongodb://localhost:27017/camsense-ai

# ─────────────────────────────────────────────
# JWT / Authentication
# ─────────────────────────────────────────────
# Required for refresh token rotation; must be a strong random string in production
JWT_SECRET=

# ─────────────────────────────────────────────
# AI Providers
# ─────────────────────────────────────────────
# Optional for local development. The app falls back to local parsing/question pools when absent.
GEMINI_API_KEY=
OLLAMA_API_URL=http://localhost:11434

# ─────────────────────────────────────────────
# Coding Evaluator
# ─────────────────────────────────────────────
# Optional. When absent, the coding sandbox uses the AI simulation fallback.
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Firebase Admin
# ─────────────────────────────────────────────
# Required only when validating real Firebase ID tokens outside demo development flows.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
