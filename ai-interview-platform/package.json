{
  "name": "ai-interview-platform",
  "version": "1.0.0",
  "description": "AI Interview Platform with mock interviews, coding tests, and detailed reports",
  "license": "MIT",
  "scripts": {
    "start": "node server/server.js",
    "preserver": "npx kill-port 5000",
    "server": "nodemon server/server.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "build:server": "npm run test && npm run lint",
    "postinstall": "npm install --prefix client",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:security": "jest --testPathPattern='security/' --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern='e2e/' --runInBand --forceExit",
    "validate-env": "node scripts/validate-env.js",
    "lint": "npx eslint . --ext .js --max-warnings 50",
    "lint:fix": "npx eslint . --ext .js --fix",
    "security:audit": "npm audit --audit-level=high",
    "security:scan": "node scripts/security-scan.js",
    "ci": "npm run lint && npm test && npm run security:audit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mongoose": "^9.7.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "pdf-parse": "^1.1.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
